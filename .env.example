# Controllus — Template de variáveis de ambiente
# Copie este arquivo para .env.local e preencha os valores reais.
# NUNCA commite o .env.local — ele está no .gitignore.

# ──────────────────────────────────────────────────────────────
# ReliefWeb API — surtos epidêmicos ativos
# A v1 foi descomissionada. A v2 exige appname aprovado (gratuito).
# Cadastro: https://apidoc.reliefweb.int/parameters#appname
# Sem esta variável: app usa dados locais (badge DEMO)
# ──────────────────────────────────────────────────────────────
RELIEFWEB_APP_NAME=seu_appname_aqui

# ──────────────────────────────────────────────────────────────
# NASA FIRMS API — focos de calor ambientais
# Cadastro gratuito: https://firms.modaps.eosdis.nasa.gov/api/area/
# Sem esta variável: painel Monitoramento usa indicadores locais
# ──────────────────────────────────────────────────────────────
NASA_API_KEY=sua_chave_aqui
